{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Harness Loop Event",
  "type": "object",
  "required": [
    "timestamp",
    "session_id",
    "event",
    "status",
    "summary"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string"
    },
    "turn_id": {
      "type": "string"
    },
    "event": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "completed",
        "failed",
        "blocked",
        "info"
      ]
    },
    "summary": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_step": {
      "type": "string"
    },
    "approval": {
      "type": "string",
      "enum": [
        "not_required",
        "requested",
        "granted",
        "rejected"
      ]
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
